{
  "name": "@nlxai/touchpoint-ui",
  "version": "1.2.7-alpha.1",
  "description": "Web UI for Touchpoint",
  "type": "module",
  "main": "lib/index.js",
  "license": "MIT",
  "author": "Peter Szerzo <peter@nlx.ai>",
  "module": "lib/index.js",
  "browser": "lib/index.umd.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "dev": "vite",
    "dev:connect": "vite --open connect-chat.html",
    "design-system": "vite --mode design-system",
    "build:design-system": "vite build --mode design-system",
    "build": "tsc && vite build",
    "lint:check": "eslint src/",
    "prepublish": "npm run build",
    "lint": "eslint src/ --fix",
    "format": "git ls-files | grep -E '\\.(js|jsx|ts|tsx|css|html)$' | xargs prettier --write",
    "test": "typedoc --emit none && vitest run",
    "tsc": "tsc",
    "update-readme:docs": "rm -rf docs/ && typedoc --excludeExternals --externalPattern src/components/ui/Icons.tsx",
    "update-readme:merge": "../../scripts/transclude-markdown.js",
    "update-readme": "npm run update-readme:docs && npm run update-readme:merge"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@nlxai/core": "^1.2.7-alpha.1",
    "@react-hookz/web": "^25.0.1",
    "@react-input/mask": "^2.0.4",
    "@rive-app/webgl2": "^2.31.5",
    "@types/json-schema": "^7.0.15",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "htm": "^3.1.1",
    "livekit-client": "^2.18.9",
    "marked": "^15.0.4",
    "ramda": "^0.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-indiana-drag-scroll": "^2.2.0",
    "react-textarea-autosize": "^8.5.6"
  },
  "devDependencies": {
    "@livekit/throws-transformer": "^0.1.8",
    "@nlxai/eslint-config": "*",
    "@rollup/plugin-replace": "^6.0.2",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.12.8",
    "@types/ramda": "^0.31.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/sdp-transform": "^2.4.9",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.0",
    "dom-accessibility-api": "^0.7.0",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.16",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0",
    "zod": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "b4642b95ec6a2752e4ef1cad2accf262f9fadaa7"
}
